rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn()         { return request.auth != null; }
    function isOwner(userId)      { return isSignedIn() && request.auth.uid == userId; }
    function getUserData()        { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function hasRole(role)        { return isSignedIn() && getUserData().role == role; }
    function isAdmin()            { return hasRole('admin'); }
    function isEmployer()         { return hasRole('employer'); }
    function isModerator()        { return hasRole('moderator'); }
    function isFreelancer()       { return hasRole('freelancer'); }
    function isAdminOrModerator() { return isAdmin() || isModerator(); }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role','moderatorPermissions'])) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Jobs ──────────────────────────────────────────────────────────────────

    match /jobs/{jobId} {
      allow read: if resource.data.status == 'active' || isAdminOrModerator() || isEmployer();
      allow create: if isEmployer() && request.resource.data.employerId == request.auth.uid;
      allow update: if (isEmployer() && resource.data.employerId == request.auth.uid) || isAdminOrModerator();
      allow delete: if (isEmployer() && resource.data.employerId == request.auth.uid) || isAdmin();
    }

    // ── Scholarships ──────────────────────────────────────────────────────────

    match /scholarships/{id} {
      allow read: if true;
      allow write: if isAdminOrModerator();
    }

    // ── Gigs ─────────────────────────────────────────────────────────────────

    match /gigs/{gigId} {
      allow read: if resource.data.status == 'open' || isSignedIn();
      allow create: if isSignedIn();
      allow update: if (isSignedIn() && resource.data.clientId == request.auth.uid) || isAdminOrModerator();
      allow delete: if (isSignedIn() && resource.data.clientId == request.auth.uid) || isAdmin();
    }

    // ── Proposals ────────────────────────────────────────────────────────────

    match /proposals/{proposalId} {
      allow read: if isSignedIn() && (resource.data.freelancerId == request.auth.uid || isAdminOrModerator());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.freelancerId == request.auth.uid || isAdminOrModerator());
      allow delete: if isSignedIn() && resource.data.freelancerId == request.auth.uid;
    }

    // ── Escrow ────────────────────────────────────────────────────────────────

    match /escrow/{escrowId} {
      allow read: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.freelancerId == request.auth.uid || isAdminOrModerator());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.freelancerId == request.auth.uid || isAdminOrModerator());
    }

    // ── Disputes ─────────────────────────────────────────────────────────────

    match /disputes/{disputeId} {
      allow read: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.freelancerId == request.auth.uid || isAdminOrModerator());
      allow create: if isSignedIn();
      allow update: if isAdminOrModerator();
    }

    // ── Portfolio ────────────────────────────────────────────────────────────

    match /portfolio/{itemId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ── Skill Badges ─────────────────────────────────────────────────────────

    match /skill_badges/{badgeId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdminOrModerator();
    }

    // ── Resumes ───────────────────────────────────────────────────────────────

    match /resumes/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ── Employer KYC ─────────────────────────────────────────────────────────

    match /employer_kyc/{kycId} {
      allow read: if isSignedIn() && (resource.data.employerId == request.auth.uid || isAdminOrModerator());
      allow create: if isSignedIn();
      allow update: if isAdminOrModerator();
    }

    // ── Reports ───────────────────────────────────────────────────────────────

    match /reports/{reportId} {
      allow read: if isAdminOrModerator();
      allow create: if isSignedIn();
      allow update: if isAdminOrModerator();
    }

    // ── Moderator Logs ───────────────────────────────────────────────────────

    match /moderator_logs/{logId} {
      allow read: if isAdminOrModerator();
      allow create: if isAdminOrModerator();
    }

    // ── Applications ─────────────────────────────────────────────────────────

    match /applications/{appId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isEmployer() || isAdminOrModerator());
      allow create: if isSignedIn();
      allow update: if isEmployer() || isAdminOrModerator();
    }

    // ── Saved Items ───────────────────────────────────────────────────────────

    match /user_saves/{saveId} {
      allow read, write: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // ── Payments ──────────────────────────────────────────────────────────────

    match /payments/{paymentId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && resource.data.status == 'pending');
    }

    // ── Admin Config ──────────────────────────────────────────────────────────

    match /admin_config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Blog ──────────────────────────────────────────────────────────────────

    match /blog/{postId} {
      allow read: if resource.data.status == 'published' || isAdminOrModerator();
      allow write: if isAdminOrModerator();
    }

    match /blog_comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminOrModerator());
    }

    // ── Referrals ─────────────────────────────────────────────────────────────

    match /referrals/{refId} {
      allow read: if isSignedIn() && resource.data.referrerId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }
  }
}
