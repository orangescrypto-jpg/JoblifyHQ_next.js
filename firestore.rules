rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isEmployer() {
      return hasRole('employer');
    }

    // ─── Users ───────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Anyone can read public profiles
      allow read: if isSignedIn();

      // Users can only write their own profile
      allow create: if isOwner(userId);

      // Users can update their own profile but NOT change their role
      allow update: if isOwner(userId)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
        || isAdmin();

      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // ─── Jobs ────────────────────────────────────────────────────────────────

    match /jobs/{jobId} {
      // Anyone can read active jobs
      allow read: if resource.data.status == 'active' || isAdmin() || isEmployer();

      // Employers can create jobs
      allow create: if isEmployer()
        && request.resource.data.employerId == request.auth.uid;

      // Employers can only update/delete their own jobs; admins can update any
      allow update: if (isEmployer() && resource.data.employerId == request.auth.uid)
        || isAdmin();

      allow delete: if (isEmployer() && resource.data.employerId == request.auth.uid)
        || isAdmin();
    }

    // ─── Scholarships ─────────────────────────────────────────────────────────

    match /scholarships/{scholarshipId} {
      allow read: if true; // Public
      allow write: if isAdmin();
    }

    // ─── Blog Posts ───────────────────────────────────────────────────────────

    match /blog/{postId} {
      // Anyone can read published posts
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin();
    }

    // ─── Blog Comments ────────────────────────────────────────────────────────

    match /blog_comments/{commentId} {
      allow read: if true;

      // Signed-in users can create comments as themselves
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      // Users can delete their own comments; admins can delete any
      allow delete: if isOwner(resource.data.userId) || isAdmin();

      allow update: if false; // Comments are immutable
    }

    // ─── Applications ─────────────────────────────────────────────────────────

    match /applications/{applicationId} {
      // Users can read their own applications
      // Employers can read applications for their jobs
      // Admins can read all
      allow read: if isOwner(resource.data.userId)
        || isAdmin()
        || (isEmployer() && resource.data.employerId == request.auth.uid);

      // Only the applicant can create their own application
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      // Only admins and employers can update status
      allow update: if isAdmin()
        || (isEmployer() && resource.data.employerId == request.auth.uid);

      allow delete: if isAdmin();
    }

    // ─── Saved Items ──────────────────────────────────────────────────────────

    match /user_saves/{saveId} {
      // Users can only read/write their own saves
      allow read: if isOwner(resource.data.userId);

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      allow delete: if isOwner(resource.data.userId);

      allow update: if false; // Saves are create/delete only
    }

    // ─── Salary Data ──────────────────────────────────────────────────────────

    match /salaries/{salaryId} {
      allow read: if true; // Public
      allow write: if isAdmin();
    }

    // ─── Employer Profiles ────────────────────────────────────────────────────

    match /employers/{employerId} {
      allow read: if true; // Public profiles
      allow write: if isOwner(employerId) || isAdmin();
    }

    // ─── Premium / Subscriptions ──────────────────────────────────────────────

    match /subscriptions/{subscriptionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow write: if isAdmin(); // Only server-side (via Cloud Functions) should write
    }

    // ─── Admin-only collections ───────────────────────────────────────────────

    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
